{
  "name": "tianqiong",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run ink:compile && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:push": "prisma db push",
    "ink:generate": "tsx scripts/generate-ink-stories.ts",
    "ink:compile": "tsx scripts/generate-ink-stories.ts && tsx scripts/compile-ink.ts",
    "ink:watch": "tsx scripts/compile-ink.ts --watch",
    "seed": "tsx scripts/seed.ts",
    "payload:importmap": "tsx scripts/generate-importmap.ts",
    "payload:seed": "curl.exe -s -X POST http://localhost:3000/api/admin/seed",
    "test:locations": "tsx scripts/location-smoke-test.ts",
    "test:content-workflow": "tsx --env-file=.env scripts/content-workflow-smoke-test.ts",
    "test:chapter1": "tsx scripts/chapter1-smoke-test.ts",
    "test:chapter1-flow": "tsx --env-file=.env scripts/testChapter1Flow.ts",
    "test:career": "tsx scripts/career-rank-smoke-test.ts",
    "content:check": "tsx --env-file=.env scripts/content-check.ts",
    "sync:sandtable": "tsx --env-file=.env scripts/sync-sandtable-payload.ts",
    "sync:npcs": "tsx --env-file=.env scripts/sync-npc-profiles-payload.ts",
    "verify:npcs": "tsx scripts/verify-npc-profiles.ts",
    "verify:npc-qa": "tsx scripts/verify-npc-data-quality.ts",
    "verify:npc-presence": "tsx scripts/verify-npc-presence.ts",
    "verify:npc-tasks": "tsx scripts/verify-npc-task-requirements.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@libsql/client": "^0.14.0",
    "@payloadcms/db-sqlite": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@prisma/client": "^5.22.0",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "graphql": "^16.14.2",
    "inkjs": "^2.4.0",
    "iron-session": "^8.0.4",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "node-cron": "^4.2.1",
    "payload": "^3.85.1",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "sharp": "^0.35.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
